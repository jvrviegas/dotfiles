## Hollow Knight
export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
  --highlight-line \
  --info=inline-right \
  --ansi \
  --layout=reverse \
  --border=none
  --color=bg+:#2d2d42 \
  --color=bg:#0d0d14 \
  --color=border:#7b68ee \
  --color=fg:#f0f0f8 \
  --color=gutter:#0d0d14 \
  --color=header:#f4c542 \
  --color=hl+:#6bb6ff \
  --color=hl:#6bb6ff \
  --color=info:#d5d5e5 \
  --color=marker:#7b68ee \
  --color=pointer:#85c1e9 \
  --color=prompt:#5cb3a0 \
  --color=query:#f0f0f8:regular \
  --color=scrollbar:#87ceeb \
  --color=separator:#f4c542 \
  --color=spinner:#7b68ee \
"
