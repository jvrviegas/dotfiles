# ALIASES
alias nppm='pnpm'
alias ppm='pnpm'
alias vim='nvim'
alias ls='eza --icons'
alias ll='eza --icons -la'
# alias cd='z'
alias nvim-config='vim ~/.config/nvim/'
alias nvim-dir='cd ~/.config/nvim'
alias proj='cd ~/Projects/'
alias ipod="cd ios && pod install && .."
alias sozsh="exec zsh"
alias za="zellij a"

. /opt/homebrew/opt/asdf/libexec/asdf.sh

# Source secrets (API keys, tokens) from a non-tracked file
[ -f "$HOME/.zsh_secrets" ] && source "$HOME/.zsh_secrets"

#Intel Platform
alias intel="arch -x86_64"

# Where should I put you?
bindkey -s ^f "tmux-sessionizer\n"

# Where should I put you in your notes?
bindkey -s ^t "tmux-notes-sessionizer\n"

# bindkey -s ^t "~/.config/colorscheme/colorscheme-selector.sh\n"

# Git
setupWorkGitlab() {
    git config user.name "João Viegas"
    git config user.email "joao.viegas@rummo.com"
}

setupPersonalGithub() {
    git config user.name "João Vitor Viegas Rêgo"
    git config user.email "jvrviegas@gmail.com"
}

gitwip() {
    git add . && git commit -m "WIP"
}

gcb () {
    branch=$( (git branch --format='%(refname:short)'; git branch -r --format='%(refname:short)') | grep -v 'HEAD' | sort -u | fzf)

    if git show-ref --verify --quiet refs/heads/"$branch"; then
        git checkout "$branch"
    else
    # branch not found locally, assume remote branch
        git checkout -b "${branch#origin/}" --track "$branch"
    fi
}

# Zoxide + fzf
zd() {
    local dir
    dir=$(zoxide query -l | fzf) && cd "$dir"
}

