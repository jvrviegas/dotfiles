{
  "general": {
    "apps": {
      "terminal": ["ghostty"],
      "audio": ["pavucontrol"],
      "explorer": ["thunar"]
    }
  },
  "bar": {
    "persistent": true,
    "workspaces": {
      "shown": 8,
      "showWindows": true,
      "activeIndicator": true
    },
    "status": {
      "showAudio": true,
      "showMicrophone": false,
      "showNetwork": true,
      "showWifi": true,
      "showBluetooth": true,
      "showBattery": true,
      "showLockStatus": false
    },
    "clock": {
      "showIcon": true
    },
    "entries": [
      { "id": "logo", "enabled": true },
      { "id": "workspaces", "enabled": true },
      { "id": "spacer", "enabled": true },
      { "id": "activeWindow", "enabled": true },
      { "id": "spacer", "enabled": true },
      { "id": "tray", "enabled": true },
      { "id": "clock", "enabled": true },
      { "id": "statusIcons", "enabled": true },
      { "id": "power", "enabled": true }
    ]
  },
  "dashboard": {
    "performance": {
      "showBattery": true,
      "showGpu": false,
      "showCpu": true,
      "showMemory": true,
      "showStorage": true,
      "showNetwork": true
    }
  },
  "services": {
    "useTwelveHourClock": false,
    "defaultPlayer": "Spotify"
  },
  "paths": {
    "wallpaperDir": "~/Pictures/Wallpapers"
  }
}
