#!/usr/bin/env bash

THEMES=("the-mandalorian" "monokai-pro" "hollow-knight")
THEME_DIR="$HOME/.config/theme"
WALLPAPER_DIR="$HOME/.config/wallpapers"
TMUX_THEME_DIR="$HOME/.config/tmux/themes"
NVIM_INIT="$HOME/.config/nvim/init.lua"
GHOSTTY_CONFIG="$HOME/.config/ghostty/config"

# Select theme via fzf or argument
THEME="${1:-$(printf '%s\n' "${THEMES[@]}" | fzf --prompt='  Theme: ' --height=10 --reverse)}"

if [[ -z "$THEME" ]]; then
  exit 0
fi

# Validate theme name
if ! printf '%s\n' "${THEMES[@]}" | grep -qx "$THEME"; then
  echo "Unknown theme: $THEME"
  echo "Available: ${THEMES[*]}"
  exit 1
fi

# Persist selection
mkdir -p "$THEME_DIR"
echo "$THEME" > "$THEME_DIR/current"

# Platform detection
IS_MACOS=false
[[ "$(uname)" == "Darwin" ]] && IS_MACOS=true

# sed -i behaves differently on macOS vs Linux
sedi() {
  if $IS_MACOS; then
    sed -i '' "$@"
  else
    sed -i "$@"
  fi
}

# --- Wallpaper ---
for ext in jpg jpeg png; do
  WALLPAPER="$WALLPAPER_DIR/${THEME}.${ext}"
  if [[ -f "$WALLPAPER" ]]; then
    if $IS_MACOS; then
      osascript -e "tell application \"System Events\" to tell every desktop to set picture to \"$WALLPAPER\""
    elif command -v hyprctl &>/dev/null; then
      hyprctl hyprpaper preload "$WALLPAPER" 2>/dev/null
      hyprctl hyprpaper wallpaper ",$WALLPAPER" 2>/dev/null
    elif command -v swaybg &>/dev/null; then
      killall swaybg 2>/dev/null; swaybg -i "$WALLPAPER" -m fill &
    fi
    break
  fi
done

# --- Ghostty ---
if [[ -f "$GHOSTTY_CONFIG" ]]; then
  sedi "s/^theme = .*/theme = ${THEME}/" "$GHOSTTY_CONFIG"
fi

# --- Neovim (persistent) ---
if [[ -f "$NVIM_INIT" ]]; then
  sedi "/^[[:space:]]*--/!s/vim\.cmd\.colorscheme '.*'/vim.cmd.colorscheme '${THEME}'/" "$NVIM_INIT"
fi

# --- Neovim (live - send to all running instances) ---
NVIM_SOCK_PATHS=("/tmp/nvim.*/0")
$IS_MACOS && NVIM_SOCK_PATHS+=("/var/folders/*/*/T/nvim.*/0")
for pattern in "${NVIM_SOCK_PATHS[@]}"; do
  for sock in $pattern; do
    [[ -S "$sock" ]] && nvim --server "$sock" --remote-send "<Cmd>colorscheme ${THEME}<CR>" 2>/dev/null &
  done
done
wait 2>/dev/null

# --- Tmux ---
if [[ -f "$TMUX_THEME_DIR/${THEME}.sh" ]]; then
  cp "$TMUX_THEME_DIR/${THEME}.sh" "$TMUX_THEME_DIR/current.sh"
  chmod +x "$TMUX_THEME_DIR/current.sh"
  bash "$TMUX_THEME_DIR/current.sh" 2>/dev/null || true
fi

echo "Switched to: $THEME"
